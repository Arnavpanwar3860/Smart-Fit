<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F2F5"
    tools:context=".DashboardActivity">

    <LinearLayout
        android:id="@+id/mainLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:id="@+id/tvGreeting"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Hello, Champion!"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="@android:color/black" />
                <TextView
                    android:id="@+id/tvStreak"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔥 1 Day Streak!"
                    android:textSize="14sp"
                    android:textColor="#FF9800"
                    android:textStyle="bold"/>
            </LinearLayout>

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switchPrivacy"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Privacy"
                android:textSize="12sp"/>
        </LinearLayout>

        <!-- FOOD DIARY Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="24dp"
            app:cardElevation="4dp"
            android:layout_marginBottom="20dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="FOOD DIARY"
                    android:textStyle="bold"
                    android:textColor="#212121"
                    android:textSize="18sp"
                    android:layout_marginBottom="16dp"/>

                <RadioGroup
                    android:id="@+id/rgMealType"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginBottom="16dp">
                    <RadioButton
                        android:id="@+id/rbBreakfast"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Breakfast"
                        android:checked="true"
                        android:buttonTint="#5C6BC0"/>
                    <RadioButton
                        android:id="@+id/rbLunch"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Lunch"
                        android:layout_marginStart="8dp"
                        android:buttonTint="#5C6BC0"/>
                    <RadioButton
                        android:id="@+id/rbDinner"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Dinner"
                        android:layout_marginStart="8dp"
                        android:buttonTint="#5C6BC0"/>
                </RadioGroup>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="16dp">

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="What did you eat?"
                        app:boxCornerRadiusBottomEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusTopStart="12dp">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etFoodInput"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="text"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <Button
                        android:id="@+id/btnLogFood"
                        android:layout_width="wrap_content"
                        android:layout_height="56dp"
                        android:layout_marginStart="12dp"
                        android:text="Log"
                        android:backgroundTint="#5C6BC0"
                        app:cornerRadius="16dp"
                        android:textAllCaps="false"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/tvMealCalories"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Total: 0 kcal • B:0 L:0 D:0 kcal"
                    android:textColor="#5C6BC0"
                    android:textSize="14sp"
                    android:layout_marginBottom="16dp"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#EEEEEE"
                    android:layout_marginBottom="16dp"/>

                <TextView
                    android:id="@+id/tvMacroSummary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="P: 0.0g • C: 0.0g • F: 0.0g"
                    android:textStyle="bold"
                    android:textColor="#212121"
                    android:textSize="16sp"
                    android:layout_marginBottom="16dp"/>

                <!-- Macros Breakdown -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">
                    <TextView
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"
                        android:text="Protein"
                        android:textSize="14sp"
                        android:textColor="#757575"/>
                    <TextView
                        android:id="@+id/tvProteinValue"
                        android:layout_width="60dp"
                        android:layout_height="wrap_content"
                        android:text="0.0g"
                        android:textSize="14sp"
                        android:textColor="#212121"/>
                    <ProgressBar
                        android:id="@+id/pbProtein"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="8dp"
                        android:progress="0"
                        android:progressTint="#4CAF50"
                        android:scaleY="2"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">
                    <TextView
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"
                        android:text="Carbs"
                        android:textSize="14sp"
                        android:textColor="#757575"/>
                    <TextView
                        android:id="@+id/tvCarbsValue"
                        android:layout_width="60dp"
                        android:layout_height="wrap_content"
                        android:text="0.0g"
                        android:textSize="14sp"
                        android:textColor="#212121"/>
                    <ProgressBar
                        android:id="@+id/pbCarbs"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="8dp"
                        android:progress="0"
                        android:progressTint="#2196F3"
                        android:scaleY="2"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <TextView
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"
                        android:text="Fat"
                        android:textSize="14sp"
                        android:textColor="#757575"/>
                    <TextView
                        android:id="@+id/tvFatValue"
                        android:layout_width="60dp"
                        android:layout_height="wrap_content"
                        android:text="0.0g"
                        android:textSize="14sp"
                        android:textColor="#212121"/>
                    <ProgressBar
                        android:id="@+id/pbFat"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="8dp"
                        android:progress="0"
                        android:progressTint="#F44336"
                        android:scaleY="2"/>
                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Profile Quick Info -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/profileCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            android:layout_marginBottom="20dp"
            app:cardBackgroundColor="#FFFFFF">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp">
                <TextView
                    android:id="@+id/tvProfileInfo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Age: 22 | Weight: 70kg | Level: Intermediate"
                    android:textSize="13sp"
                    android:alpha="0.8"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Fitness Score Meter -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/scoreCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="24dp"
            app:cardElevation="4dp"
            android:layout_marginBottom="20dp"
            app:cardBackgroundColor="#673AB7">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp"
                android:gravity="center">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Fitness Score"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"/>
                <TextView
                    android:id="@+id/tvFitnessScore"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="#FFFFFF"
                    android:textSize="48sp"
                    android:textStyle="bold"/>
                <TextView
                    android:id="@+id/tvScoreLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🟡 Medium"
                    android:textColor="#D1C4E9"
                    android:textSize="14sp"
                    android:textStyle="bold"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- AI Fitness Insight Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/predictionCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="20dp"
            app:cardBackgroundColor="#1E1E1E"
            android:layout_marginBottom="20dp"
            app:cardElevation="4dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🤖 AI Insight"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"/>
                <TextView
                    android:id="@+id/aiInsight"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="Analyzing your activity patterns..."
                    android:textColor="#CCCCCC"
                    android:textSize="14sp"/>
                <TextView
                    android:id="@+id/tvPrediction"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:visibility="gone" />
                <TextView
                    android:id="@+id/tvTrend"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:visibility="gone" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Main Progress Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/dataContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="24dp"
            app:cardElevation="8dp"
            android:layout_marginBottom="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp"
                android:gravity="center">

                <TextView
                    android:id="@+id/tvGoalTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Daily Steps Goal"
                    android:textStyle="bold"
                    android:textSize="18sp"
                    android:layout_marginBottom="16dp"/>

                <TextView
                    android:id="@+id/stepsText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="48sp"
                    android:textColor="#2196F3"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/tvDistance"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0.00 km"
                    android:textSize="16sp"
                    android:textColor="#4CAF50"
                    android:layout_marginBottom="8dp"/>

                <ProgressBar
                    android:id="@+id/progressBar"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="12dp"
                    android:max="8000"
                    android:progress="0"
                    android:progressTint="#2196F3"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Daily Challenge Section -->
        <TextView
            android:id="@+id/tvChallengeTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🎯 Today's Challenge"
            android:textStyle="bold"
            android:textSize="18sp"
            android:layout_marginBottom="12dp"
            android:textColor="@android:color/black"/>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/challengeCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            android:layout_marginBottom="20dp"
            app:cardBackgroundColor="#E8F5E9">
            <TextView
                android:id="@+id/challengeText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp"
                android:text="Complete 6000 steps today!"
                android:textColor="#2E7D32"
                android:textSize="16sp"
                android:textStyle="bold"/>
        </com.google.android.material.card.MaterialCardView>

        <!-- Vital Signs Section -->
        <TextView
            android:id="@+id/tvVitalsTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Real-Time Vitals (AI Sensing)"
            android:textStyle="bold"
            android:textSize="18sp"
            android:layout_marginBottom="12dp"
            android:textColor="@android:color/black"/>

        <GridLayout
            android:id="@+id/vitalsGrid"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="2"
            android:alignmentMode="alignMargins"
            android:columnOrderPreserved="false"
            android:layout_marginBottom="8dp">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                app:cardCornerRadius="16dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="❤️ Heart Rate" android:textSize="12sp"/>
                    <TextView android:id="@+id/tvHeartRate" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="72 BPM" android:textSize="20sp" android:textStyle="bold" android:textColor="#E91E63"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                app:cardCornerRadius="16dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp" android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🧠 Stress" android:textSize="12sp"/>
                    <TextView android:id="@+id/tvStress" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Low" android:textSize="20sp" android:textStyle="bold" android:textColor="#9C27B0"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                app:cardCornerRadius="16dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp" android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🩸 BP" android:textSize="12sp"/>
                    <TextView android:id="@+id/tvBP" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="120/80" android:textSize="20sp" android:textStyle="bold" android:textColor="#F44336"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                app:cardCornerRadius="16dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp" android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🔥 Calories" android:textSize="12sp"/>
                    <TextView android:id="@+id/tvTotalCalories" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0 kcal" android:textSize="20sp" android:textStyle="bold" android:textColor="#FF9800"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </GridLayout>

        <!-- Daily Habit Tracker Section -->
        <TextView
            android:id="@+id/tvHabitTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Daily Habit Tracker"
            android:textStyle="bold"
            android:textSize="18sp"
            android:layout_marginBottom="12dp"
            android:textColor="@android:color/black"/>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/habitCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="20dp"
            android:layout_marginBottom="20dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">
                <CheckBox android:id="@+id/checkWater" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Drink 2L Water"/>
                <CheckBox android:id="@+id/checkMeditation" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="10 Min Meditation"/>
                <CheckBox android:id="@+id/checkSleep" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="8 Hours Sleep"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Health Connect Sync Button -->
        <Button
            android:id="@+id/btnConnectHealth"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Sync with Health Connect"
            android:layout_marginBottom="20dp"
            android:backgroundTint="#2196F3"
            app:cornerRadius="12dp"
            android:textAllCaps="false"/>

        <!-- Navigation Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="20dp">
            <Button
                android:id="@+id/workoutBtn"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Track Activity"
                android:layout_marginEnd="8dp"
                android:backgroundTint="#FF9800"
                app:cornerRadius="12dp"
                android:textAllCaps="false"/>
            <Button
                android:id="@+id/historyBtn"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="View History"
                android:layout_marginStart="8dp"
                android:backgroundTint="#4CAF50"
                app:cornerRadius="12dp"
                android:textAllCaps="false"/>
        </LinearLayout>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
