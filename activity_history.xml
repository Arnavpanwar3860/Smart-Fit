<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F2F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Secure Health History"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@android:color/black" />

        <TextView
            android:id="@+id/tvSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AI Tracking &amp; Activity Log"
            android:textSize="14sp"
            android:alpha="0.7"
            android:layout_marginBottom="24dp"/>

        <!-- Activity Overview -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="20dp"
            app:cardElevation="4dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📊 Activity Summary"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:layout_marginBottom="12dp"/>

                <TextView
                    android:id="@+id/historySteps"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Steps: --"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#2196F3"/>

                <TextView
                    android:id="@+id/historyDistance"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Distance: --"
                    android:textSize="14sp"
                    android:layout_marginTop="4dp"/>

                <TextView
                    android:id="@+id/historyFitnessScore"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Fitness Score: --"
                    android:textSize="14sp"
                    android:layout_marginTop="4dp"
                    android:textStyle="bold"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- AI Tracker History -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="20dp"
            app:cardElevation="4dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🧠 Last AI Tracked Session"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:layout_marginBottom="12dp"/>

                <TextView
                    android:id="@+id/historyWorkout"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Workout: --"
                    android:textSize="16sp"
                    android:textColor="#FF9800"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/historyVitals"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Vitals Logged: --"
                    android:textSize="14sp"
                    android:layout_marginTop="4dp"
                    android:alpha="0.8"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Consistency & Insights -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="20dp"
            app:cardElevation="4dp"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="#E8F5E9">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔥 Consistency &amp; Insights"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:textColor="#2E7D32"
                    android:layout_marginBottom="12dp"/>

                <TextView
                    android:id="@+id/historyStreak"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Streak: -- Days"
                    android:textSize="15sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/historySummary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Analyzing your history..."
                    android:textSize="14sp"
                    android:layout_marginTop="8dp"
                    android:lineSpacingExtra="4dp"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <Button
            android:id="@+id/btnBack"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Back to Dashboard"
            android:layout_marginTop="8dp"
            app:cornerRadius="16dp"/>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
